{
  "initial": "TOPIC_PENDING",
  "terminal": ["PUBLISHED", "FAILED", "REJECTED"],
  "states": {
    "TOPIC_PENDING": {"next": "TOPIC_READY", "skill": "travel-video-topic-research"},
    "TOPIC_READY": {"next": "SCRIPT_READY", "skill": "travel-video-scriptwriter"},
    "SCRIPT_READY": {"next": "BRAND_INSERT_READY", "skill": "travel-video-brand-insert"},
    "BRAND_INSERT_READY": {"next": "ASSET_PLAN_READY", "skill": "travel-video-asset-generation"},
    "ASSET_PLAN_READY": {"next": "MEDIA_READY", "skill": "travel-video-media-generation", "retry": 3},
    "MEDIA_READY": {"next": "MEDIA_STORED", "skill": "travel-video-oss-storage", "retry": 3},
    "MEDIA_STORED": {"next": "FACT_CHECK_READY", "skill": "travel-video-fact-check"},
    "FACT_CHECK_READY": {"next": "EDIT_PLAN_READY", "skill": "travel-video-editing-plan"},
    "EDIT_PLAN_READY": {"next": "RENDER_READY", "skill": "travel-video-render-worker", "retry": 2},
    "RENDER_READY": {"next": "FINAL_STORED", "skill": "travel-video-oss-storage", "retry": 3},
    "FINAL_STORED": {"next": "QA_READY", "skill": "travel-video-qa-review"},
    "QA_READY": {"next": "PUBLISH_PENDING", "on_human_review": "HUMAN_REVIEW_PENDING", "on_reject": "REJECTED"},
    "HUMAN_REVIEW_PENDING": {"next": "PUBLISH_PENDING"},
    "PUBLISH_PENDING": {"next": "PUBLISHED", "skill": "travel-video-publisher", "retry": 2}
  },
  "failure_policy": {
    "retryable_errors": ["timeout", "rate_limited", "network", "transient_provider_error"],
    "non_retryable_errors": ["missing_credentials", "policy_blocked", "invalid_prompt", "unsupported_format"],
    "default_failed_state": "FAILED"
  }
}
