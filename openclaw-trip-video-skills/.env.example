# DashScope / Alibaba Cloud Model Studio
DASHSCOPE_API_KEY=
DASHSCOPE_REGION=beijing
DASHSCOPE_VIDEO_MODEL=wan2.6-t2v
DASHSCOPE_IMAGE_MODEL=wan2.6-image
DASHSCOPE_TTS_MODEL=qwen3-tts-flash
DASHSCOPE_TTS_VOICE=Cherry

# Media generation behavior
DASHSCOPE_POLL_TIMEOUT_SECONDS=900
DASHSCOPE_POLL_INTERVAL_SECONDS=15

# Alibaba Cloud OSS via ossutil
OSSUTIL_PATH=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PUBLIC_BASE_URL=

# Rendering
FFMPEG_PATH=
FFPROBE_PATH=
RENDER_OUTPUT_DIR=./output/rendered

# Optional publishing service
PUBLISHER_ENDPOINT=
PUBLISHER_TOKEN=
